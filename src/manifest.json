{
  "manifest_version": 3,
  "name": "f_translate",
  "version": "1.0.0",
  "description": "Strips the ?tl= query parameter from Reddit URLs to prevent unwanted auto-translation.",
  "permissions": ["declarativeNetRequest"],
  "host_permissions": ["*://*.reddit.com/*"],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "f_translate@broemp",
      "strict_min_version": "113.0"
    }
  }
}
